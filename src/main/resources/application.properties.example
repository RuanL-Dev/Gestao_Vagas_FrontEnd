########################################
# SERVER
########################################
server.port=${SERVER_PORT:8080}
spring.application.name=api_cursos

########################################
# SPRING PROFILE (opcional)
########################################
# Ex.: dev, prod
spring.profiles.active=${SPRING_PROFILES_ACTIVE:dev}

########################################
# DATASOURCE / PROPERTIES 
########################################
spring.datasource.url=${DATABASE_URL}
spring.datasource.username=${DATABASE_USERNAME}
spring.datasource.password=${DATABASE_PASSWORD}
security.token.secret=${SECURITY_TOKEN_SECRET}
token.sonar=${TOKEN_SONAR}

########################################
# JPA / HIBERNATE
########################################
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect

########################################
# LOGGING
########################################
logging.level.root=${LOG_LEVEL_ROOT:INFO}
logging.level.org.hibernate.SQL=${LOG_LEVEL_SQL:INFO}
logging.level.org.springframework.web=${LOG_LEVEL_WEB:INFO}

########################################
# REDIS 
########################################
spring.data.redis.host=${REDIS_HOST:localhost}
spring.data.redis.port=${REDIS_PORT:6379}

########################################
# MAIL 
########################################
spring.mail.host=${MAIL_HOST:smtp.example.com}
spring.mail.port=${MAIL_PORT:587}
spring.mail.username=${MAIL_USER:}
spring.mail.password=${MAIL_PASS:}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.from=${MAIL_FROM:no-reply@example.com}

########################################
# JWT / SECRETS 
########################################
security.token.secret=${JWT_SECRET:changeme-in-local-env}
security.token.expiration=${JWT_EXPIRATION:3600000}

########################################
# AWS S3 (opcional)
########################################
cloud.aws.region.static=${AWS_REGION:sa-east-1}
cloud.aws.credentials.access-key=${AWS_ACCESS_KEY:}
cloud.aws.credentials.secret-key=${AWS_SECRET_KEY:}
app.s3.bucket=${AWS_S3_BUCKET:}

########################################
# OUTROS (exemplos)
########################################
# app.feature.toggleX=${FEATURE_TOGGLE_X:false}
# thirdparty.api.url=${TP_API_URL:https://api.example.com}